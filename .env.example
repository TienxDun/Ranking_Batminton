# GEMINI_API_KEY: Khóa API của Google Gemini (nếu có sử dụng các tính năng AI).
GEMINI_API_KEY="YOUR_GEMINI_API_KEY"

# APP_URL: URL chạy thực tế của ứng dụng (mặc định local là http://localhost:3000).
APP_URL="http://localhost:3000"

# VITE_GOOGLE_SCRIPT_URL: URL Web App của Google Apps Script (để dùng Google Sheets làm database đồng bộ).
# Bỏ trống nếu muốn chạy database local qua Express server (file data.json).
VITE_GOOGLE_SCRIPT_URL=""
